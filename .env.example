# =============================================================================
# notAEC Environment Configuration
# Copy this file to .env and fill in secure values before running.
# NEVER commit .env to version control.
# =============================================================================

# --- Flask ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# --- Database (Docker Compose) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=votingdb
MYSQL_USER=votinguser
MYSQL_PASSWORD=CHANGE_ME
VOTING_ADMIN_USER=voting_admin
VOTING_ADMIN_PASS=CHANGE_ME
VOTING_VOTER_USER=voting_voter
VOTING_VOTER_PASS=CHANGE_ME

# --- Encryption ---
# 32-byte key, Base64 encoded. Generate:
# python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
VOTER_PII_KEY_BASE64=CHANGE_ME

# --- Blind Index Pepper (for driver licence hash) ---
# High-entropy secret mixed into deterministic hashes. Generate:
# python -c "import secrets; print(secrets.token_hex(32))"
LICENSE_HASH_PEPPER=CHANGE_ME

# --- Geo-Filtering ---
GEO_FILTER_ENABLED=True
ALLOWED_COUNTRIES=AU

# --- MFA ---
ENABLE_MFA=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# --- Vault (optional) ---
VAULT_TOKEN=vault-dev-token

# --- Logging ---
LOG_LEVEL=INFO
DEBUG_DB_BIND=false
